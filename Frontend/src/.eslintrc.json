{
    "env": {
      "browser": true,
      "es2021": true
      // Removed "node": true from here, as it's now specific to overrides
    },
    "extends": [
      "eslint:recommended",
      "plugin:react/recommended",
      "plugin:react/jsx-runtime"
    ],
    "parserOptions": {
      "ecmaVersion": 2021,
      "sourceType": "module", // Default for React JSX files
      "ecmaFeatures": {
        "jsx": true
      }
    },
    "plugins": [
      "react"
    ],
    "rules": {
      "indent": [
        "error",
        2
      ],
      "linebreak-style": [
        "error",
        "unix"
      ],
      "quotes": [
        "error",
        "single"
      ],
      "semi": [
        "error",
        "always"
      ],
      "no-unused-vars": [
        "warn",
        { "argsIgnorePattern": "^_" }
      ],
      "react/react-in-jsx-scope": "off", // Not needed for React 17+ JSX transform
      "react/prop-types": "off" // Disabled prop-types validation
    },
    "settings": {
      "react": {
        "version": "detect" // Automatically detects the React version
      }
    },
    "overrides": [
      {
        "files": ["tailwind.config.js"], // Apply to tailwind config
        "env": {
          "node": true // Explicitly enable Node.js environment for this file
        },
        "parserOptions": {
          "sourceType": "commonjs" // Explicitly set to CommonJS for this file
        }
      },
      {
        "files": ["vite.config.js"], // Apply to vite config
        "env": {
          "node": true // Explicitly enable Node.js environment for this file
        },
        "parserOptions": {
          "sourceType": "module" // Explicitly set to module for this file
        }
      }
    ]
  }